# Copy to `.env.local` and fill in. All VITE_-prefixed vars are exposed to the
# browser bundle — only put non-secret identifiers here (the Cognito pool +
# IAM role are the security boundary, not these IDs).

# AWS region hosting your Cognito pool, Map resource, GeoRoutes, Jobs, and S3 bucket.
# Everything MUST be in the same region.
VITE_AWS_REGION=us-east-1

# Cognito Identity Pool ID with unauthenticated access enabled.
# Format: <region>:<uuid>, e.g. us-east-1:00000000-1111-2222-3333-444444444444
VITE_COGNITO_IDENTITY_POOL_ID=

# ARN of the Cognito unauthenticated IAM role. The app assumes this directly via
# the STS classic flow (so iam:PassRole works for the Jobs API). Format:
# arn:aws:iam::<account>:role/AmazonLocationDemoUnauthRole
VITE_COGNITO_UNAUTH_ROLE_ARN=

# The four OpenData map styles, each a separate V1 Map resource created via
# `aws location create-map --configuration Style=<Style>`. At least VITE_MAP_NAME
# is required; the others are optional and only appear in the style switcher when
# set. Styles: VectorOpenDataStandardLight / VectorOpenDataStandardDark /
# VectorOpenDataVisualizationLight / VectorOpenDataVisualizationDark.
VITE_MAP_NAME=DemoOpenDataLight
VITE_MAP_NAME_DARK=DemoOpenDataDark
VITE_MAP_NAME_VIZ_LIGHT=DemoOpenDataVizLight
VITE_MAP_NAME_VIZ_DARK=DemoOpenDataVizDark

# S3 bucket (versioning ENABLED, same region) for Jobs API Parquet input/output.
VITE_VALIDATION_BUCKET=

# IAM role ARN the Jobs service assumes to read/write the S3 bucket.
# Trust policy must allow geo.amazonaws.com to assume it.
VITE_JOBS_EXECUTION_ROLE_ARN=
