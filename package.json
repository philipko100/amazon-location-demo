{
  "name": "amazon-location-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web app demonstrating Amazon Location Service: interactive map (GetMapTile V1 / OpenData via MapLibre), CalculateRouteMatrix (V2 GeoRoutes), and bulk address validation (Jobs API ValidateAddress).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-geo-routes": "^3.700.0",
    "@aws-sdk/client-location": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws/amazon-location-utilities-auth-helper": "^1.3.0",
    "apache-arrow": "^17.0.0",
    "maplibre-gl": "^5.5.0",
    "papaparse": "^5.4.1",
    "parquet-wasm": "^0.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0"
  }
}
